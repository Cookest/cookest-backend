# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://cookest:yourpassword@localhost:5432/cookest

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_this_must_be_32_chars_min

ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=2592000

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ── AI Chat (Ollama) ──────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# RAG embeddings model (must be pulled on the Ollama server)
OLLAMA_EMBED_MODEL=nomic-embed-text
# Number of nutrition-knowledge chunks retrieved per query
RAG_TOP_K=5

# ── Nearby stores (OpenStreetMap Overpass) ─────────────────────────────────────
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,auth_api=debug

# ── S3 Object Storage ─────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cookest-images
S3_REGION=us-east-1
# S3_PUBLIC_URL=http://localhost:9000/cookest-images
